<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>AI CAD Mockup</title>

    <!-- Import model-viewer -->
    <script type="module"
      src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js">
    </script>
  </head>
  <body style="margin:0;background:#0b1020;color:white;font-family:sans-serif;">

    <!-- Simple top bar to evoke “AI CAD tool” -->
    <div style="padding:10px 20px;border-bottom:1px solid #20273a;">
      <strong>NovaCAD AI</strong> · Intuitive 3D Design
    </div>

    <!-- 3D model viewer area -->
    <model-viewer
      src="model.glb"
      alt="AI CAD 3D part"
      style="width:100%;height:80vh;background:#050814;"
      camera-controls
      auto-rotate
      interaction-prompt="auto">
    </model-viewer>

  </body>
</html>
